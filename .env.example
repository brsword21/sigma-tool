# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: OpenAI  |  Model: gpt-4o-mini  |  SDK: openai (Python)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# ── Supabase ──────────────────────────────────────────────────────────────────
# Utwórz projekt na https://supabase.com → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Klucz z https://firecrawl.dev → Dashboard → API Keys
# Firecrawl jest JEDYNYM źródłem ogłoszeń w tym MVP (brak scrapera OLX).
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_TIMEOUT_SECONDS=20

# ── API ───────────────────────────────────────────────────────────────────────
# Dozwolone originy CORS (oddzielone przecinkiem)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Host i port serwera
HOST=0.0.0.0
PORT=8000
DEMO_TIMEOUT_SECONDS=180

# Ustaw wyłącznie przy świadomym uruchamianiu testów używających płatnych usług.
RUN_LIVE_TESTS=0
