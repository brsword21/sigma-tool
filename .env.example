# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: OpenAI  |  Model: gpt-4o-mini  |  SDK: openai (Python)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# ── Supabase ──────────────────────────────────────────────────────────────────
# Utwórz projekt na https://supabase.com → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
# Publiczny klucz publishable/anon; może być używany w przeglądarce.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Wyłącznie backend. Nigdy nie kopiuj tej wartości do prototypu ani kodu klienta.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend React (`frontend/.env.local`) ───────────────────────────────────
# Skopiuj poniższe dwie PUBLICZNE wartości do `frontend/.env.local`.
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Klucz z https://firecrawl.dev → Dashboard → API Keys
# Firecrawl obsługuje oferty OLX oraz benchmark najniższej ceny nowego produktu na Ceneo.
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_TIMEOUT_SECONDS=20

# ── API ───────────────────────────────────────────────────────────────────────
# Dozwolone originy CORS (oddzielone przecinkiem)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Host i port serwera
HOST=0.0.0.0
PORT=8000
DEMO_TIMEOUT_SECONDS=180

# Ustaw wyłącznie przy świadomym uruchamianiu testów używających płatnych usług.
RUN_LIVE_TESTS=0
